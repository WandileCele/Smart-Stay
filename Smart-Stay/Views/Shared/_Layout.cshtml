<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart_Stay</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Smart_Stay.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/footer.css" asp-append-version="true" />
</head>
<body>
    <div>
        <header class="bg-dark bg-opacity-75 py-3">
            <div class="container d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center">
                    <img />
                    <h2 class="text-white m-0">SMART STAY</h2>
                </div>

                <div>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-light rounded-pill me-2">Sign Up</a>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-light rounded-pill me-2">Login</a>
                </div>
            </div>
        </header>
        <div>

        </div>
    </div>
    
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-section">

        <div class="container">

            <div class="row gy-5">

                <!-- ================= LEFT ================= -->
                <div class="col-lg-3">

                    <div class="footer-logo">

                        <i class="bi bi-house-door"></i>

                        <div>
                            <h2>SMART STAY</h2>
                            <span>Find. Book. Stay Smart.</span>
                        </div>

                    </div>

                    <p class="footer-description">
                        Smart Stay connects students and visitors with trusted
                        accommodation across Port Elizabeth, making it easy
                        to find a place that feels like home.
                    </p>

                    <h4 class="footer-heading mt-5">
                        FOLLOW US
                    </h4>

                    <div class="social-icons">

                        <a href="#">
                            <i class="bi bi-facebook"></i>
                        </a>

                        <a href="#" class="instagram">
                            <i class="bi bi-instagram"></i>
                        </a>

                        <a href="#" class="linkedin">
                            <i class="bi bi-linkedin"></i>
                        </a>

                        <a href="#" class="twitter">
                            <i class="bi bi-twitter-x"></i>
                        </a>

                    </div>

                </div>

                <!-- ================= AREAS ================= -->

                <div class="col-lg-3">

                    <h3 class="footer-title">
                        AREAS IN PORT ELIZABETH
                    </h3>

                    <div class="title-line"></div>

                    <ul class="footer-list">

                        <li>
                            <i class="bi bi-geo-alt"></i>
                            <span>Walmer</span>
                        </li>

                        <li>
                            <i class="bi bi-geo-alt"></i>
                            <span>North End</span>
                        </li>

                        <li>
                            <i class="bi bi-geo-alt"></i>
                            <span>Humewood</span>
                        </li>

                        <li>
                            <i class="bi bi-geo-alt"></i>
                            <span>Summerstrand</span>
                        </li>

                        <li>
                            <i class="bi bi-geo-alt"></i>
                            <span>Newton Park</span>
                        </li>

                        <li>
                            <i class="bi bi-geo-alt"></i>
                            <span>Central</span>
                        </li>

                    </ul>

                </div>

                <!-- ================= QUICK LINKS ================= -->

                <div class="col-lg-3">

                    <h3 class="footer-title">
                        QUICK LINKS
                    </h3>

                    <div class="title-line"></div>

                    <ul class="footer-links">

                        <li>
                            <a href="#">
                                <i class="bi bi-chevron-right"></i>
                                Home
                            </a>
                        </li>

                        <li>
                            <a href="#">
                                <i class="bi bi-chevron-right"></i>
                                Browse Properties
                            </a>
                        </li>

                        <li>
                            <a href="#">
                                <i class="bi bi-chevron-right"></i>
                                About Us
                            </a>
                        </li>

                        <li>
                            <a href="#">
                                <i class="bi bi-chevron-right"></i>
                                Contact Us
                            </a>
                        </li>

                        <li>
                            <a href="#">
                                <i class="bi bi-chevron-right"></i>
                                List Your Property
                            </a>
                        </li>

                    </ul>

                </div>

                <!-- ================= RIGHT ================= -->

                <div class="col-lg-3">

                    <h3 class="footer-title">
                        SUPPORT
                    </h3>

                    <div class="title-line"></div>

                    <ul class="footer-links">

                        <li>
                            <a href="#">
                                <i class="bi bi-chevron-right"></i>
                                How It Works
                            </a>
                        </li>

                        <li>
                            <a href="#">
                                <i class="bi bi-chevron-right"></i>
                                FAQs
                            </a>
                        </li>

                        <li>
                            <a href="#">
                                <i class="bi bi-chevron-right"></i>
                                Privacy Policy
                            </a>
                        </li>

                        <li>
                            <a href="#">
                                <i class="bi bi-chevron-right"></i>
                                Terms & Conditions
                            </a>
                        </li>

                        <li>
                            <a href="#">
                                <i class="bi bi-chevron-right"></i>
                                Support Center
                            </a>
                        </li>

                    </ul>

                    <div class="contact-section">

                        <h3 class="footer-title">
                            CONTACT US
                        </h3>

                        <div class="title-line"></div>

                        <div class="contact-item">
                            <i class="bi bi-telephone"></i>
                            <span>+27 41 000 0000</span>
                        </div>

                        <div class="contact-item">
                            <i class="bi bi-envelope"></i>
                            <span>support@smartstay.co.za</span>
                        </div>

                        <div class="contact-item">
                            <i class="bi bi-geo-alt"></i>
                            <span>Port Elizabeth, South Africa</span>
                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="footer-bottom">

            <div class="container">

                <div class="bottom-content">

                    <div>
                        © 2026 Smart Stay. All Rights Reserved.
                    </div>

                    <div class="divider"></div>

                    <div>
                        <i class="bi bi-heart"></i>
                        Proudly made by <strong>Meta Minds</strong>
                    </div>

                </div>

            </div>

        </div>

    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
