<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart_Stay</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Smart_Stay.styles.css" asp-append-version="true" />
</head>
<body>
    <div>
        <header class="bg-dark bg-opacity-75 py-3">
            <div class="container d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center">
                    <img />
                    <h2 class="text-white m-0">SMART STAY</h2>
                </div>

                <div>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-light rounded-pill me-2">Sign Up</a>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-light rounded-pill me-2">Login</a>
                </div>
            </div>
        </header>
        <div>

        </div>
    </div>
    
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
